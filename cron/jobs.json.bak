    {
      "id": "e4619913-6556-4194-97c2-aeaa0bf3cded",
      "agentId": "xiaodong",
      "name": "每周跨境风险扫描",
      "description": "每周一 09:00 调用 xiaodong_crossborder_scout 执行近 30 天默认口径的跨境风险扫描",
      "enabled": true,
      "createdAtMs": 1773378305617,
      "updatedAtMs": 1775236667936,
      "schedule": {
        "kind": "cron",
        "expr": "0 9 * * 1",
        "tz": "Asia/Shanghai"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "你现在以跨境电商公司的老板/运营总监视角做周扫描。目标不是资讯汇总，而是：1) 识别会导致卖家亏损/封店/合规处罚/成本上升的风险；2) 识别政策变化带来的可执行机会。重点范围：欧洲企业注册（法国/德国）、欧盟VAT/税务、支付、物流、合规政策，以及指定平台（16个平台）招商政策、卖家门槛、风控与处罚变化。输出必须分为：A高风险（立即影响，给出影响对象+损失路径+建议动作）；B中风险（持续观察，给出触发条件）；C机会（窗口期+适配卖家类型+行动建议）。每条必须附来源链接与日期（绝对日期），至少双来源交叉验证；没有证据的不写。禁止空泛趋势、禁止与卖家收益无关信息。若本次无高质量情报，明确返回“本次无有效可执行情报”，并给出失败原因与下次改进策略。",
        "timeoutSeconds": 420
      },
      "delivery": {
        "mode": "announce",
        "channel": "feishu",
        "to": "ou_87bb675cf1a555992cf71df25f860c63",
        "bestEffort": false
      },
      "state": {
        "nextRunAtMs": 1775437200000,
        "lastRunAtMs": 1775235218922,
        "lastRunStatus": "ok",
        "lastStatus": "ok",
        "lastDurationMs": 166120,
        "lastDeliveryStatus": "delivered",
        "consecutiveErrors": 0,
        "lastDelivered": true
      },
      "failureAlert": {
        "after": 2,
        "channel": "feishu",
        "to": "ou_87bb675cf1a555992cf71df25f860c63",
        "cooldownMs": 43200000
      }
    },
