{
  "id": "mobile-runtime-plugin",
  "name": "Mobile Runtime Plugin",
  "description": "Expose mobile_* tools with a file-backed control plane, mac-proxy execution, and android-node bridge support.",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "repoRoot": {
        "type": "string"
      },
      "registryPath": {
        "type": "string"
      },
      "stateDir": {
        "type": "string"
      },
      "adbPath": {
        "type": "string"
      },
      "autoGlmDir": {
        "type": "string"
      },
      "flowDir": {
        "type": "string"
      },
      "defaultBackend": {
        "type": "string"
      },
      "defaultTaskTimeoutMs": {
        "type": "number"
      },
      "autoGlmTimeoutMs": {
        "type": "number"
      }
    }
  },
  "uiHints": {}
}
