                "collectionName": "${MEM0_QDRANT_COLLECTION}",
                "dimension": 1536,
                "embeddingModelDims": 1536,
                "host": "qdrant.99uwen.com",
                "https": true,
                "port": 443
              },
              "provider": "qdrant"
            }
          },
          "searchThreshold": 0.3,
          "topK": 8,
          "userId": "${MEM0_BASE_USER_ID}"
        },
        "enabled": true,
        "hooks": {
          "allowPromptInjection": false
        }
      },
